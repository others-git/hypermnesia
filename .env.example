# Copy to .env and adjust.

HM_DATABASE_URL=postgresql://hypermnesia:hypermnesia@localhost:5432/hypermnesia

# Embeddings (local / CPU). provider: fastembed | sentence_transformers | ollama
HM_EMBEDDING_PROVIDER=fastembed
HM_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# HM_EMBEDDING_DIM=384            # optional; auto-detected from the model
# HM_OLLAMA_BASE_URL=http://localhost:11434

# Recall / write behaviour
HM_DEDUPE_THRESHOLD=0.92
HM_DEFAULT_TOP_K=8
# Drop search hits below this cosine similarity (0.0 disables). Default tuned for
# bge-small-en-v1.5, whose cosine range is compressed (unrelated ~0.30-0.45,
# relevant ~0.55+); re-tune if you change embedding models.
HM_SEARCH_MIN_SIMILARITY=0.4
# Ranking blend: score = w_sim*similarity + w_recency*recency + w_importance*importance
HM_SCORE_WEIGHT_SIMILARITY=1.0
HM_SCORE_WEIGHT_RECENCY=0.25
HM_SCORE_WEIGHT_IMPORTANCE=0.15
HM_RECENCY_HALF_LIFE_DAYS=30
HM_IMPORTANCE_CAP=2.0
HM_RERANK_CANDIDATE_MULTIPLIER=5

# Server
HM_HOST=127.0.0.1
HM_PORT=8765

# Auth: map bearer tokens to a principal and the scopes it may read/write.
HM_REQUIRE_AUTH=true
HM_AUTH_TOKENS={"dev-token":{"principal":"dev","scopes":["default","shared","user:dev-test"]}}
